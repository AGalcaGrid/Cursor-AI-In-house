{
  "version": "1.0.0",
  "projectName": "support-ticket-api",
  "org": "your-org-name",
  "severity": {
    "threshold": "medium",
    "failOn": "high"
  },
  "ignore": {
    "SNYK-PYTHON-JINJA2-1012994": {
      "reason": "No user input reaches template rendering",
      "expires": "2025-12-31T00:00:00.000Z"
    }
  },
  "patch": {},
  "exclude": {
    "global": [
      "node_modules",
      "venv",
      ".venv",
      "__pycache__",
      "*.test.js",
      "*.spec.js",
      "test_*.py",
      "*_test.py"
    ]
  },
  "cli": {
    "args": [
      "--all-projects",
      "--detection-depth=4"
    ]
  },
  "api": {
    "token": "${SNYK_TOKEN}"
  },
  "policies": {
    "vulnerabilities": {
      "autoFix": true,
      "autoFixMajorVersion": false
    },
    "license": {
      "severity": "medium",
      "allowedLicenses": [
        "MIT",
        "Apache-2.0",
        "BSD-2-Clause",
        "BSD-3-Clause",
        "ISC",
        "Python-2.0",
        "PSF-2.0"
      ],
      "deniedLicenses": [
        "GPL-3.0",
        "AGPL-3.0"
      ]
    }
  },
  "monitoring": {
    "enabled": true,
    "frequency": "daily"
  },
  "integrations": {
    "github": {
      "enabled": true,
      "autoRemediation": true,
      "prChecks": true
    },
    "slack": {
      "enabled": false,
      "webhook": "${SLACK_WEBHOOK_URL}",
      "notifyOn": ["high", "critical"]
    }
  },
  "reports": {
    "format": ["json", "html"],
    "outputDir": "./reports/security"
  },
  "customRules": {
    "enabled": false,
    "rulesDir": "./security/custom-rules"
  }
}
